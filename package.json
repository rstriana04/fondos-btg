{
  "name": "fondos-btg",
  "version": "1.0.0",
  "private": true,
  "description": "FondosBTG Monorepo — Flutter & Angular investment funds management app",
  "workspaces": [
    "packages/shared/*"
  ],
  "scripts": {
    "api:start": "cd packages/shared/mock-api && node server.js",
    "flutter:run": "cd apps/flutter-app && flutter run -d chrome",
    "angular:serve": "cd apps/angular-app && ng serve --port 4200",
    "start:all": "concurrently \"npm run api:start\" \"npm run angular:serve\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
